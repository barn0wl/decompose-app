generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ────────────────────────────────────────────────────────────────

enum StopType {
  taxi_stop
  gbaka_station
  landmark
  zone_boundary
}

enum TransportType {
  communal_taxi
  gbaka
  sotra_bus
  walking
}

enum SuggestionStatus {
  pending
  approved
  rejected
  auto_rejected
}

// ─── MODELS ──────────────────────────────────────────────────────────────

model Stop {
  id        String   @id @default(uuid())
  name      String
  commune   String
  latitude  Float
  longitude Float
  type      StopType
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // PostGIS geometry column
  geom      String?  @db.Text

  connectionsFrom Connection[] @relation("FromStop")
  connectionsTo   Connection[] @relation("ToStop")
  suggestedFrom   SuggestedConnection[] @relation("SuggestionFrom")
  suggestedTo     SuggestedConnection[] @relation("SuggestionTo")
}

model Vote {
  id           String   @id @default(uuid())
  connectionId String
  connection   Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  deviceId     String
  vote         Int      @db.SmallInt
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([connectionId, deviceId])
  @@index([deviceId])
  @@index([connectionId])
  @@index([createdAt])
}

model Connection {
  id String @id @default(uuid())

  fromStopId String
  fromStop   Stop  @relation("FromStop", fields: [fromStopId], references: [id])

  toStopId String
  toStop   Stop  @relation("ToStop", fields: [toStopId], references: [id])

  transportType    TransportType
  basePrice        Int
  durationMinutes  Int
  routeDescription String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  upvotes          Int    @default(0)
  downvotes        Int    @default(0)
  voteScore        Int    @default(0)

  votes Vote[]
}

// ─── SUGGESTED CONNECTION  ─────────────────────────────────────────

model SuggestedConnection {
  id String @id @default(uuid())

  fromStopId      String
  fromStop        Stop           @relation("SuggestionFrom", fields: [fromStopId], references: [id])
  toStopId        String
  toStop          Stop           @relation("SuggestionTo", fields: [toStopId], references: [id])
  transportType   TransportType
  basePrice       Int
  durationMinutes Int
  routeDescription String?

  submittedBy     String
  submittedAt     DateTime       @default(now())
  status          SuggestionStatus @default(pending)
  confirmations   Int            @default(0)
  confirmationThreshold Int      @default(5)
  confirmedBy     Json?
  rejectedBy      String?
  rejectedReason  String?
  rejectedAt      DateTime?
  approvedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}
